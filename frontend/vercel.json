{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://second-life-commerce-backend-ffpa.onrender.com/api/:path*"
    },
    {
      "source": "/static/:path*",
      "destination": "https://second-life-commerce-backend-ffpa.onrender.com/static/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
